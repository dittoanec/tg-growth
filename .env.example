# Telegram Growth Intelligence — Local Config
# Copy this to .env and fill in your keys

# Required: Telegram API credentials (from https://my.telegram.org)
TG_API_ID=
TG_API_HASH=

# Required: Your channel username (without @)
CHANNEL_USERNAME=your_channel_username

# Required: Claude API key (server-side only, never exposed to browser)
CLAUDE_API_KEY=

# Required: Auth token for collector API (make up any random string, use the same value for both)
COLLECTOR_TOKEN=
VITE_COLLECTOR_TOKEN=

# Optional: Telegram Bot token (from @BotFather, for basic channel info)
VITE_TG_BOT_TOKEN=

# Optional: Slack incoming webhook URL
VITE_SLACK_WEBHOOK=
